DEEPSEEK_API_KEY="sk-xxx"

# FastAPI 服务配置
API_HOST=127.0.0.1
API_PORT=8001
API_RELOAD=true

# CORS 跨域配置：允许的前端源地址，多个用逗号分隔；* 表示允许所有
CORS_ORIGINS=*

# LLM Provider: "deepseek" or "claude" (default: deepseek)
LLM_PROVIDER=claude

# Claude (Anthropic) config
ANTHROPIC_BASE_URL="https://lab.iwhalecloud.com/gpt-proxy/anthropic"
ANTHROPIC_AUTH_TOKEN="ailab_xxx"
CLAUDE_MODEL=claude-4.6-sonnet

CHROMA_DB_PATH=./data/chroma_db
SQLITE_DB_PATH=./data/metadata.db
MYSQL_URL=mysql+pymysql://user:password@10.10.22.46:3306/database
# Oracle format: oracle+oracledb://user:password@host:port/?service_name=your_service_name
ORACLE_URL=your_oracle_url_here
PDM_FILES_DIR=./files
MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2

# 多轮对话配置
# 会话历史持久化文件路径（自动创建）
CONVERSATION_PERSIST_PATH=./data/conversations.json
# 每个会话最多保留的消息数（超出后自动裁剪最早的消息，防止 token 超限）
MAX_MESSAGES_PER_SESSION=50

# 知识源 & 代码索引配置
# Git 克隆仓库存放目录
REPOS_DIR=./data/repos
# 本地 Java 项目路径（用于代码索引）
LOCAL_CODE_DIR=/Users/wuchangping/projects/iWhaleCloud/git/pc90-product/pc/code
# 索引的文件扩展名（逗号分隔）
CODE_INDEX_EXTENSIONS=.java,.js,.hbs,.xml,.yml,.yaml,.properties
# 代码片段最大行数
CODE_CHUNK_MAX_LINES=100

# LLM 响应超时时间（秒）
LLM_TIMEOUT=120